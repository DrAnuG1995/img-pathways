# Copy to .env.local for local dev, and set these in Vercel for production.

# Public site URL — used for canonical URLs, sitemap and OpenGraph.
# Leave unset locally (defaults to the placeholder in lib/site.ts).
NEXT_PUBLIC_SITE_URL=https://imgpathways.au

# --- Lead capture → Notion -------------------------------------------------
# The "IMG Pathways — Leads" database already exists in the connected Notion
# workspace (created during setup). To let the website write to it:
#   1. Create an internal integration at https://www.notion.so/my-integrations
#   2. Open the Leads database → ••• → Connections → add that integration
#   3. Set the two vars below (the token is secret; the DB id is not)
NOTION_TOKEN=
NOTION_LEADS_DB_ID=4c6e97c07d554efcb6fd82ecfc8a9ee7
